# Database Configuration
# For Neon DB / PostgreSQL: postgresql://user:password@host/dbname
DATABASE_URL=sqlite:///./placio.db

# Security
# Generate a strong key using: openssl rand -hex 32
SECRET_KEY=placio_production_secret_key_change_me_immediately

# CORS Configuration (Comma separated list of origins)
# Example: http://localhost:5173,https://placio.vercel.app
BACKEND_CORS_ORIGINS=http://localhost:5173
